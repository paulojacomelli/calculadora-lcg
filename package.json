{
  "name": "pyro-planetary",
  "private": true,
  "version": "1.1.198-beta",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite --port 3000\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_PORT=3000 electron .\"",
    "build:exe": "npm run build && electron-builder -w",
    "build:apk": "npm run build && npx cap sync android"
  },
  "build": {
    "appId": "com.lcgeletro.calculadorashopee",
    "productName": "Calculadora Shopee",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/pwa-512.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "decimal.js": "^10.6.0",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.4"
  }
}
