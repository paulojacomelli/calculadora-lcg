rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que qualquer pessoa leia a senha para validação
    match /config/access {
      allow read: if true;
      allow write: if false; // Ninguém pode alterar via app, só pelo console
    }
    
    // Regra padrão para o resto do banco (protegido)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
